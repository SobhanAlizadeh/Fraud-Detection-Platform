{
  "title": "Fraud Detection Dashboard",
  "uid": "fraud-detection",
  "timezone": "browser",
  "panels": [
    {
      "title": "Total Transactions",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "count(transaction_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "title": "Fraud Rate",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [
        {
          "expr": "(sum(fraud_predictions_total) / count(transaction_total)) * 100",
          "legendFormat": "Fraud Rate"
        }
      ]
    },
    {
      "title": "API Response Time (p95)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "title": "Transactions Over Time",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "rate(transaction_total[1h])",
          "legendFormat": "Transactions"
        }
      ]
    },
    {
      "title": "Fraud Predictions",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "rate(fraud_predictions_total[1h])",
          "legendFormat": "Predictions"
        }
      ]
    },
    {
      "title": "Top Merchants by Fraud",
      "type": "barchart",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "topk(5, sum by (merchant) (fraud_predictions_total))",
          "legendFormat": "{{merchant}}"
        }
      ]
    },
    {
      "title": "Model Performance",
      "type": "table",
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 12},
      "targets": [
        {
          "expr": "model_accuracy",
          "legendFormat": "Accuracy"
        },
        {
          "expr": "model_f1_score",
          "legendFormat": "F1 Score"
        },
        {
          "expr": "model_roc_auc",
          "legendFormat": "ROC-AUC"
        }
      ]
    }
  ],
  "schemaVersion": 36
}
